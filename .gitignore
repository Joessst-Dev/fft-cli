# Build output.
#
# The binary is named `fft` and so is the package directory (cmd/fft), so a bare
# `fft` pattern would ignore the source tree itself. Both places it actually gets
# built are listed explicitly instead.
/dist/
/fft
/cmd/fft/fft
/cmd/fft/fft.exe
/docsgen

# Test and coverage output
*.out
*.test
coverage.*

# Local environment
.env
.env.local

# Local AI tooling. Track shared agents and skills so cloud routines (which run
# off a fresh clone) can use them; keep working memory out — the notes reference
# a private tenant — along with any local settings.
.claude/*
!.claude/agents/
!.claude/skills/

# Documentation site (VitePress). The generated Markdown under docs/guide and
# docs/reference is committed and drift-gated; only the Node install and the build
# output are transient. Scoped to docs/ so nothing here can catch the source tree.
docs/node_modules/
docs/.vitepress/dist/
docs/.vitepress/cache/

# Editor / OS
.DS_Store
